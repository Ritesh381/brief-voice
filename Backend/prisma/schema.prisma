// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL") // e.g., "file:./briefvoice.db"
}

/// 1. Core Meeting Model
/// Tracks the global lifecycle state of the meeting audio and processing pipeline.
model Meeting {
  id        String   @id @default(uuid())
  filename  String   // Original name of the uploaded file
  audioPath String   // Disk storage path for reference or re-indexing
  status    String   @default("uploaded") // "uploaded" | "processing" | "transcribed" | "processed" | "error"
  createdAt DateTime @default(now())

  // Relations
  transcript  Transcript?
  summary     MeetingSummary?
  actionItems ActionItem[]
  embeddings  Embedding[]
}

/// 2. Transcript Model
/// Holds the high-level full text output. 
model Transcript {
  id        String   @id @default(uuid())
  meetingId String   @unique
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  fullText  String   // Combined unstructured transcription text
  createdAt DateTime @default(now())

  // Relations
  segments  TranscriptSegment[]
}

/// 3. Transcript Segment Model
/// Critical for Speaker Diarization, Analytics (Speaking Time), and RAG (Chunking).
model TranscriptSegment {
  id           String     @id @default(uuid())
  transcriptId String
  transcript   Transcript @relation(fields: [transcriptId], references: [id], onDelete: Cascade)
  
  speaker      String     // Raw system generated label (e.g., "Speaker A", "Speaker 0")
  speakerName  String?    // Post-processed user-assigned custom name (e.g., "Narendra")
  text         String     // The actual phrase spoken in this segment
  startMs      Int        // Segment start timestamp in milliseconds
  endMs        Int        // Segment end timestamp in milliseconds
  
  createdAt    DateTime   @default(now())

  @@index([transcriptId])
}

/// 4. Meeting Summary Model
/// Structurally maps out the NLP outputs required by the Gemini service.
model MeetingSummary {
  id               String   @id @default(uuid())
  meetingId        String   @unique
  meeting          Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  
  // Stored as semi-structured text formats (or Stringified JSON arrays)
  attendees        String   // e.g., "[\"Narendra\", \"Ritesh\", \"Harshita\"]"
  keyDecisions     String   // Clean markdown format or JSON array
  discussionPoints String   // High level summary of discussion topics
  openQuestions    String   // Bullet points of unanswered items
  nextSteps        String   // Fast access text summarizing future actions
  
  createdAt        DateTime @default(now())
}

/// 5. Action Items Model
/// Tracks explicit commitments extractable from transcripts and makes them interactive.
model ActionItem {
  id        String   @id @default(uuid())
  meetingId String
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  
  task      String   // Description of what needs to be done
  owner     String?  // Parsed name of the assignee (e.g., "Narendra" or "Speaker A")
  deadline  String?  // Parsed target timeframe text (e.g., "Friday", "By end of sprint")
  completed Boolean  @default(false) // Toggleable via frontend checklist UI
  
  createdAt DateTime @default(now())

  @@index([meetingId])
}

/// 6. Embedding Model
/// Stores vector embeddings of transcript/summary chunks for semantic search.
/// Vectors are persisted as JSON-stringified float arrays; cosine similarity
/// is computed in the application layer (SQLite has no native vector type).
model Embedding {
  id        String  @id @default(uuid())
  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  chunkType String  // "transcript" | "summary"
  speaker   String? // Speaker label for transcript chunks
  startMs   Int? // Segment start for jump-to-timestamp on results
  text      String // The chunk text returned as the result snippet
  vector    String // JSON-stringified number[] embedding

  createdAt DateTime @default(now())

  @@index([meetingId])
}